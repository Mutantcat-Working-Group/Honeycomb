foreach(required_var QML_FILE CMAKE_FILE COMMON_BACKEND MAC_BACKEND)
    if(NOT DEFINED ${required_var})
        message(FATAL_ERROR "Missing required variable: ${required_var}")
    endif()
endforeach()

file(READ "${QML_FILE}" qml_source)
if(NOT qml_source MATCHES "import Honeycomb")
    message(FATAL_ERROR "Window inspector QML must import the registered Honeycomb module")
endif()
if(NOT qml_source MATCHES "function onCapturingChanged\\(\\)" OR NOT qml_source MATCHES "rootWindow\\.hide\\(\\)")
    message(FATAL_ERROR "Inspector window must move out of the way while capturing")
endif()
if(NOT qml_source MATCHES "hiddenForCapture" OR NOT qml_source MATCHES "rootWindow\\.show\\(\\)")
    message(FATAL_ERROR "Inspector window must be restored after capturing")
endif()
if(NOT qml_source MATCHES "id: startCaptureButton" OR NOT qml_source MATCHES "text: startCaptureButton\\.text")
    message(FATAL_ERROR "Capture button content must reference the button instead of its Row parent")
endif()
if(NOT qml_source MATCHES "windowInspectorPickAnchor")
    message(FATAL_ERROR "Inspector UI must expose anchor picking as the primary action")
endif()
if(NOT qml_source MATCHES "inspector\\.registerHotkey\\(\\)")
    message(FATAL_ERROR "The configured global hotkey must be registered when the picker opens")
endif()

file(READ "${CMAKE_FILE}" cmake_source)
if(cmake_source MATCHES "SOURCES[^)]*WindowElementInspector_mac\\.mm[^)]*WindowElementInspector_win\\.cpp[^)]*WindowElementInspector_linux\\.cpp")
    message(FATAL_ERROR "Platform inspector backends must not all be compiled into one target")
endif()
if(NOT cmake_source MATCHES "target_sources\\(appHoneycomb PRIVATE src/WindowElementInspector_mac\\.mm\\)")
    message(FATAL_ERROR "macOS inspector backend must be selected conditionally")
endif()
if(NOT cmake_source MATCHES "codesign[^\n]*--identifier[^\n]*org\\.mutantcat\\.honeycomb" OR
   NOT cmake_source MATCHES "--requirements[^\n]*designated[^\n]*org\\.mutantcat\\.honeycomb")
    message(FATAL_ERROR "macOS app must receive a stable post-build code signature")
endif()

file(READ "${MAC_BACKEND}" mac_source)
string(REGEX MATCH "void init\\(WindowElementInspector \\*insp\\)[^{]*\\{[^}]*\\}" mac_init "${mac_source}")
if(mac_init MATCHES "kAXTrustedCheckOptionPrompt")
    message(FATAL_ERROR "Opening the inspector must not trigger the macOS accessibility prompt")
endif()
if(NOT mac_source MATCHES "bool requestAccessibilityPermission\\(WindowElementInspector \\*insp\\)" OR
   NOT mac_source MATCHES "kAXTrustedCheckOptionPrompt: @YES")
    message(FATAL_ERROR "macOS accessibility prompting must be an explicit user action")
endif()
if(NOT mac_source MATCHES "kAXTrustedCheckOptionPrompt: @NO")
    message(FATAL_ERROR "macOS passive permission status must explicitly disable prompting")
endif()
if(mac_source MATCHES "canReadExternalAccessibility")
    message(FATAL_ERROR "macOS permission state must not rely on heuristic cross-process probes")
endif()
if(NOT mac_source MATCHES "com\\.apple\\.accessibility\\.universalAccessAuthWarn")
    message(FATAL_ERROR "macOS foreground status must ignore the accessibility authorization dialog")
endif()
if(mac_source MATCHES "QVariantMap info = elementToMap\\(el\\)")
    message(FATAL_ERROR "macOS hit-test result is shadowed and will always be returned empty")
endif()
if(NOT mac_source MATCHES "AXUIElementGetPid\\(el")
    message(FATAL_ERROR "macOS target application metadata must come from the picked element PID")
endif()
if(NOT mac_source MATCHES "kCGEventLeftMouseDown")
    message(FATAL_ERROR "macOS anchor picking must capture the next global left click")
endif()
if(NOT mac_source MATCHES "keyCode == 53")
    message(FATAL_ERROR "macOS anchor picking must support Escape cancellation")
endif()

string(FIND "${mac_source}" "static WindowElementInspector *g_inspector" declaration_pos)
string(FIND "${mac_source}" "g_inspector = insp" first_use_pos)
if(declaration_pos LESS 0 OR first_use_pos LESS 0 OR declaration_pos GREATER first_use_pos)
    message(FATAL_ERROR "macOS inspector instance must be declared before its first use")
endif()

file(READ "${COMMON_BACKEND}" common_source)
if(NOT common_source MATCHES "setHasAccessibility\\(PlatformBackend::refreshAccessibility\\(this\\)\\)")
    message(FATAL_ERROR "The initial accessibility state must be stored during construction")
endif()
if(NOT common_source MATCHES "requestAccessibilityPermission")
    message(FATAL_ERROR "The inspector must expose explicit accessibility permission requests")
endif()
if(NOT common_source MATCHES "void WindowElementInspector::captureAtPoint\\(int x, int y\\)")
    message(FATAL_ERROR "Platform pickers must report the exact clicked anchor coordinates")
endif()
if(NOT common_source MATCHES "PlatformBackend::beginPicking\\(this\\)")
    message(FATAL_ERROR "Capture timeout must enter anchor-picking mode instead of taking a pointer snapshot")
endif()
if(NOT common_source MATCHES "【指向组件提示词】")
    message(FATAL_ERROR "Natural output must be a component-pointing prompt for AI agents")
endif()
